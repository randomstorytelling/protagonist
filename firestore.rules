rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each signed-in user can read/write ONLY their own game-state doc.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Everything else (incl. the private _feed/* token store) is default-deny for clients.
    // The cloud feeds reach _feed/* and users/* via the project-owner OAuth token (admin context),
    // which bypasses these rules — clients never can.
  }
}
